DATABRICKS_SERVER_HOSTNAME=dbc-c8b4d0cc-1da2.cloud.databricks.com
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
DATABRICKS_ARTICLES_TABLE=main.news_ai.articles_clean
DATABRICKS_ARTICLES_SINCE_DAYS=14

DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=news_ai

NEWS_SOURCES=vnexpress,cafef,genk,diendandoanhnghiep
# Legacy: category_pagination mode ignores this value.
MAX_ARTICLES_PER_SOURCE=20
CRAWL_MODE=category_pagination
DISCOVER_CATEGORIES=true
MAX_PAGES_PER_CATEGORY=5
STOP_AFTER_EMPTY_PAGES=3
STOP_AFTER_DUPLICATE_PAGES=3
REQUEST_DELAY_SECONDS=1
MAX_CONCURRENT_REQUESTS=4
REQUEST_TIMEOUT_SECONDS=15
REQUEST_RETRY_COUNT=2
NEWS_CRAWLER_USER_AGENT=databricks-news-ai-demo/1.0

LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BATCH_SIZE=64
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=news_articles

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=180

RAG_RETRIEVE_TOP_N=12
RAG_BROAD_RETRIEVE_TOP_N=30
RAG_TOP_K=4
RAG_MIN_SCORE=0.35
RAG_MAX_CHUNKS_PER_ARTICLE=1
RAG_DEBUG=false
CHUNK_SIZE=700
CHUNK_OVERLAP=120
SUMMARY_MAX_CHUNKS=10
PROMPT_MAX_CONTEXT_CHARS=12000
PROMPT_DEBUG_MAX_CHARS=4000
